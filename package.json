    "chart.js": "^4.5.1",
    "chartjs-adapter-date-fns": "^3.0.0",
    "vue": "^3.5.33",
    "vue-chartjs": "^5.3.3",
    "vue-router": "^4.6.4",
    "vuetify": "^3.12.5"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/compiler-sfc": "^3.5.33",
    "eslint": "^8.57.1",
    "eslint-plugin-vue": "^9.33.0",
    "sass": "^1.99.0",
    "vite": "^7.3.2",
    "vite-plugin-vuetify": "^2.1.3"
  },
  "eslintConfig": {
    "root": true,
    "extends": [
